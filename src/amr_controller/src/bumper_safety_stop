#include <string>
#include <memory>
#include <vector>

#include "rclcpp/rclcpp.hpp"
#include "sensor_msgs/msg/joint_state.hpp"
#include "std_msgs/msg/bool.hpp"

using std::placeholders::_1;

class BumperSafetyStop : public rclcpp::Node
{
public:
  BumperSafetyStop()
  : Node("bumper_safety_stop_node"),
    prev_stop_(false)
  {
    declare_parameter<std::string>("bumper_safety_stop_topic", "bumper_safety_stop");
    declare_parameter<std::string>("front_bumper_joint",       "Front_Bumper_Joint");
    declare_parameter<std::string>("rear_bumper_joint",        "Rear_Bumper_Joint");
    declare_parameter<double>     ("press_threshold",          0.002);

    stop_topic_        = get_parameter("bumper_safety_stop_topic").as_string();
    front_joint_name_  = get_parameter("front_bumper_joint").as_string();
    rear_joint_name_   = get_parameter("rear_bumper_joint").as_string();
    press_threshold_   = get_parameter("press_threshold").as_double();

    joint_state_sub_ = create_subscription<sensor_msgs::msg::JointState>(
      "joint_states", 10,
      std::bind(&BumperSafetyStop::jointStateCallback, this, _1));

    safety_stop_pub_ = create_publisher<std_msgs::msg::Bool>(stop_topic_, 10);

    RCLCPP_INFO(get_logger(),
      "BumperSafetyStop started. Watching joints: [%s, %s] | threshold: %.4f m",
      front_joint_name_.c_str(), rear_joint_name_.c_str(), press_threshold_);
  }

private:
  std::string stop_topic_;
  std::string front_joint_name_;
  std::string rear_joint_name_;
  double      press_threshold_;
  bool        prev_stop_;

  rclcpp::Subscription<sensor_msgs::msg::JointState>::SharedPtr joint_state_sub_;
  rclcpp::Publisher<std_msgs::msg::Bool>::SharedPtr             safety_stop_pub_;

  void jointStateCallback(const sensor_msgs::msg::JointState & msg)
  {
    bool front_pressed = false;
    bool rear_pressed  = false;

    for (size_t i = 0; i < msg.name.size(); ++i)
    {
      if (msg.name[i] == front_joint_name_)
      {
        front_pressed = std::abs(msg.position[i]) > press_threshold_;
      }
      else if (msg.name[i] == rear_joint_name_)
      {
        rear_pressed = std::abs(msg.position[i]) > press_threshold_;
      }
    }

    bool any_pressed = front_pressed || rear_pressed;

    // Only publish on state change — mirrors the pattern in ultrasonic_safety_stop
    if (any_pressed != prev_stop_)
    {
      std_msgs::msg::Bool out;
      out.data = any_pressed;
      safety_stop_pub_->publish(out);

      RCLCPP_WARN(get_logger(),
        "Bumper state changed → %s  [front=%s | rear=%s]",
        any_pressed     ? "STOP (PRESSED)" : "CLEAR",
        front_pressed   ? "PRESSED"        : "clear",
        rear_pressed    ? "PRESSED"        : "clear");

      prev_stop_ = any_pressed;
    }
  }
};

int main(int argc, char * argv[])
{
  rclcpp::init(argc, argv);
  rclcpp::spin(std::make_shared<BumperSafetyStop>());
  rclcpp::shutdown();
  return 0;
}