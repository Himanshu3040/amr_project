<?xml version="1.0"?>

<robot name="amr" xmlns:xacro="http://ros.org/wiki/xacro">


  <xacro:arg name="is_ignition" default="true"/>


  <xacro:arg name="is_sim" default="true"/>


  <xacro:include filename="$(find amr_description)/urdf/amr_gazebo.xacro" />

  <xacro:include filename="$(find amr_description)/urdf/amr_ros2_control.xacro" />

  <xacro:property name="base_length"   value="0.600"/>
  <xacro:property name="base_width"    value="0.500"/>
  <xacro:property name="base_height"   value="0.180"/>
  <xacro:property name="base_mass"     value="30.0"/>

  <xacro:property name="wheel_radius"     value="0.075"/>
  <xacro:property name="wheel_width"      value="0.050"/>
  <xacro:property name="wheel_mass"       value="1"/>

  <xacro:property name="wheel_separation" value="0.480"/>
  
  <xacro:property name="caster_radius"    value="0.020"/>
  <xacro:property name="caster_mass"      value="1"/>

  <xacro:property name="lidar_x"         value="0.08"/>
  <xacro:property name="lidar_y"         value="0.08"/>
  <xacro:property name="lidar_z"         value="0.07"/>
  <xacro:property name="lidar_mass"         value="1"/>

  <xacro:property name="imu_x"           value="0.04331"/>
  <xacro:property name="imu_y"           value="0.0"/>
  <xacro:property name="imu_z"           value="1"/>

  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(w*w+h*h)/12}" ixy="0.0" ixz="0.0"
        iyy="${m*(l*l+h*h)/12}" iyz="0.0"
        izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(3*r*r+h*h)/12}" ixy="0.0" ixz="0.0"
        iyy="${m*(3*r*r+h*h)/12}" iyz="0.0"
        izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${2*m*r*r/5}" ixy="0.0" ixz="0.0"
        iyy="${2*m*r*r/5}" iyz="0.0"
        izz="${2*m*r*r/5}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>


  <!-- ==================== Base Link ==================== -->


  <link name="base_link">
    <xacro:box_inertia m="${base_mass}"
                       l="${base_length}"
                       w="${base_width}"
                       h="${base_height}"/>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Base_Link.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Base_Link.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  
  <joint name="Base_Footprint_Joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>


  <!-- ==================== Right Wheel ==================== -->


  <link name="Right_Wheel">
    <xacro:cylinder_inertia m="${wheel_mass}"
                            r="${wheel_radius}"
                            h="${wheel_width}"/>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Right_Wheel.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.9 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.050"/>
        <!-- <mesh filename="package://amr_description/meshes/Right_Wheel.STL" scale="0.001 0.001 0.001"/> -->
      </geometry>
    </collision>
  </link>

  <joint name="Right_Wheel_Joint" type="continuous">
    <parent link="base_link"/>
    <child  link="Right_Wheel"/>
    <origin xyz="0 -${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- ==================== Left Wheel ==================== -->

  <link name="Left_Wheel">
    <xacro:cylinder_inertia m="${wheel_mass}"
                            r="${wheel_radius}"
                            h="${wheel_width}"/>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Left_Wheel.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.9 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.050"/>
        <!-- <mesh filename="package://amr_description/meshes/Left_Wheel.STL" scale="0.001 0.001 0.001"/> -->
      </geometry>
    </collision>
  </link>

  <joint name="Left_Wheel_Joint" type="continuous">
    <parent link="base_link"/>
    <child  link="Left_Wheel"/>
    <origin xyz="0 ${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- ==================== Caster ==================== -->


  <link name="Caster">
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Caster.STL" scale="0.001 0.001 0.001" /> 
      </geometry>
      <material
        name="">
        <color rgba="0.6 0.6 0.6 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Caster.STL" scale="0.001 0.001 0.001" /> 
      </geometry>
    </collision>
  </link>

  <joint name="Caster_Joint" type="fixed">
    <parent link="base_link"/>
    <child  link="Caster"/>
    <origin xyz="0.290 0 -0.041" rpy="0 0 0"/>
  </joint>


<!-- ==================== Lidar ==================== -->


  <link name="Lidar_Link">
    <xacro:box_inertia m="${lidar_mass}"
                       l="${lidar_x}"
                       w="${lidar_y}"
                       h="${lidar_z}"/>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 ${pi}" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Lidar.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.2 0.2 0.2 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
      <geometry>
        <box size="0.100 0.070 0.055"/>
        <!-- <mesh filename="package://amr_description/meshes/Lidar.STL" /> -->
      </geometry>
    </collision>
  </link>

  <joint name="Laser_Joint" type="fixed">
    <parent link="base_link"/>
    <child  link="Lidar_Link"/>
    <origin xyz="0.1992 0.0011384 0.183" rpy="0 0 0"/>
  </joint>


<!-- ==================== IMU  ==================== -->


  <link name="IMU_Link">
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/IMU.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/IMU.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="IMU_Joint" type="fixed">
    <parent link="base_link"/>
    <child  link="IMU_Link"/>
    <origin xyz="0.10331 0 0.0095" rpy="0 0 0"/>
  </joint>


  <!-- ==================== FRONT BUMPER ==================== -->
  <link name="Front_Bumper">
    <inertial>
      <mass value="0.192323065808925" />
      <inertia
        ixx="0.006519743425104"
        ixy="-9.22815526894101E-09"
        ixz="-3.89179634633383E-05"
        iyy="0.000789318174926477"
        iyz="-1.36378898549255E-09"
        izz="0.0072231575614127" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Front_Bumper.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Front_Bumper.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="Front_Bumper_Joint" type="prismatic">
    <parent link="base_link"/>
    <child  link="Front_Bumper"/>
    <origin xyz="0.328 0.00125 -0.007" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.01" upper="0" effort="20" velocity="0.1"/>
  </joint>

  <!-- ==================== REAR BUMPER ==================== -->
  <link name="Rear_Bumper">
    <inertial>
      <mass value="0.14844816742278" />
      <inertia
        ixx="0.00438148818103443"
        ixy="-4.75358055127294E-11"
        ixz="2.59046953973231E-05"
        iyy="0.00045961717701518"
        iyz="-7.97996736519186E-13"
        izz="0.00477574022877043" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://amr_description/meshes/Rear_Bumper.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Rear_Bumper.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="Rear_Bumper_Joint" type="prismatic">
    <parent link="base_link"/>
    <child  link="Rear_Bumper"/>
    <origin xyz="-0.20913 0.00125 -0.007" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.01" effort="20" velocity="0.1"/>
  </joint>

</robot>